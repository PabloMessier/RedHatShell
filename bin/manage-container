#!/bin/bash

# Container management script for RHEL shell

# Load common functions and configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/common.sh"

# Function to show usage
show_usage() {
    echo "Usage: manage-container [COMMAND] [OPTIONS]"
    echo ""
    echo "Commands:"
    echo "  status      Show container status"
    echo "  start       Start the container"
    echo "  stop        Stop the container"
    echo "  restart     Restart the container"
    echo "  remove      Remove the container (keeps image)"
    echo "  reset       Remove container and image (full reset)"
    echo "  logs        View container logs"
    echo "  inspect     Inspect container details"
    echo "  stats       Show container resource usage"
    echo "  backup      Backup container to tar archive"
    echo "  restore     Restore container from backup (requires file path)"
    echo ""
}

# Parse command
COMMAND="${1:-status}"

case "$COMMAND" in
    status)
        if check_container_exists; then
            STATUS=$(podman inspect -f '{{.State.Status}}' "$CONTAINER_NAME")
            RUNNING=$(podman inspect -f '{{.State.Running}}' "$CONTAINER_NAME")
            print_info "Container: $CONTAINER_NAME"
            print_info "Status: $STATUS"
            print_info "Running: $RUNNING"
            if [ "$RUNNING" == "true" ]; then
                podman stats --no-stream "$CONTAINER_NAME"
            fi
        else
            print_warning "Container '$CONTAINER_NAME' does not exist"
        fi
        
        if check_image_exists; then
            print_info "Image: $IMAGE_NAME (exists)"
        else
            print_warning "Image '$IMAGE_NAME' does not exist"
        fi
        ;;
        
    start)
        if check_container_exists; then
            print_info "Starting container..."
            podman start "$CONTAINER_NAME"
            print_success "Container started"
        else
            print_error "Container does not exist. Run 'redhat-shell' to create it."
        fi
        ;;
        
    stop)
        if check_container_exists; then
            print_info "Stopping container..."
            podman stop "$CONTAINER_NAME"
            print_success "Container stopped"
        else
            print_warning "Container does not exist"
        fi
        ;;
        
    restart)
        if check_container_exists; then
            print_info "Restarting container..."
            podman restart "$CONTAINER_NAME"
            print_success "Container restarted"
        else
            print_error "Container does not exist"
        fi
        ;;
        
    remove)
        if check_container_exists; then
            print_warning "This will remove the container but keep the image"
            read -p "Are you sure? (y/N): " -n 1 -r
            echo
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                print_info "Removing container..."
                podman rm -f "$CONTAINER_NAME"
                print_success "Container removed"
            else
                print_info "Cancelled"
            fi
        else
            print_warning "Container does not exist"
        fi
        ;;
        
    reset)
        print_warning "This will remove the container AND the image"
        read -p "Are you sure? (y/N): " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            if check_container_exists; then
                print_info "Removing container..."
                podman rm -f "$CONTAINER_NAME"
            fi
            if check_image_exists; then
                print_info "Removing image..."
                podman rmi "$IMAGE_NAME"
            fi
            print_success "Complete reset done. Run 'build-image' to rebuild."
        else
            print_info "Cancelled"
        fi
        ;;
        
    logs)
        if check_container_exists; then
            podman logs "$CONTAINER_NAME"
        else
            print_error "Container does not exist"
        fi
        ;;
        
    inspect)
        if check_container_exists; then
            podman inspect "$CONTAINER_NAME"
        else
            print_error "Container does not exist"
        fi
        ;;
        
    stats)
        if check_container_exists; then
            if check_container_running; then
                podman stats "$CONTAINER_NAME"
            else
                print_warning "Container is not running"
            fi
        else
            print_error "Container does not exist"
        fi
        ;;
        
    backup)
        if ! check_container_exists; then
            print_error "Container does not exist"
            exit 1
        fi
        
        # Create backup directory if it doesn't exist
        BACKUP_DIR="$HOME/.redhat-shell/backups"
        mkdir -p "$BACKUP_DIR"
        
        # Generate backup filename with timestamp
        TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
        BACKUP_FILE="$BACKUP_DIR/redhat-shell_${TIMESTAMP}.tar"
        
        print_info "Creating backup of container '$CONTAINER_NAME'..."
        print_info "Backup location: $BACKUP_FILE"
        
        # Stop container if running (to ensure consistent backup)
        WAS_RUNNING=false
        if check_container_running; then
            print_info "Stopping container for backup..."
            podman stop "$CONTAINER_NAME" > /dev/null
            WAS_RUNNING=true
        fi
        
        # Export container to tar
        if podman export "$CONTAINER_NAME" -o "$BACKUP_FILE"; then
            BACKUP_SIZE=$(du -h "$BACKUP_FILE" | cut -f1)
            print_success "Backup created successfully!"
            print_info "  └─ File: $BACKUP_FILE"
            print_info "  └─ Size: $BACKUP_SIZE"
            
            # Restart container if it was running
            if [ "$WAS_RUNNING" = true ]; then
                print_info "Restarting container..."
                podman start "$CONTAINER_NAME" > /dev/null
            fi
        else
            print_error "Failed to create backup"
            
            # Restart container if it was running
            if [ "$WAS_RUNNING" = true ]; then
                podman start "$CONTAINER_NAME" > /dev/null
            fi
            exit 1
        fi
        ;;
        
    restore)
        BACKUP_FILE="$2"
        
        if [ -z "$BACKUP_FILE" ]; then
            print_error "Please specify a backup file to restore"
            echo "Usage: manage-container restore <backup-file>"
            echo ""
            echo "Available backups:"
            BACKUP_DIR="$HOME/.redhat-shell/backups"
            if [ -d "$BACKUP_DIR" ] && [ -n "$(ls -A $BACKUP_DIR/*.tar 2>/dev/null)" ]; then
                ls -lh "$BACKUP_DIR"/*.tar | awk '{print "  " $9 " (" $5 ")"}'
            else
                echo "  No backups found in $BACKUP_DIR"
            fi
            exit 1
        fi
        
        if [ ! -f "$BACKUP_FILE" ]; then
            print_error "Backup file not found: $BACKUP_FILE"
            exit 1
        fi
        
        print_warning "This will remove the current container and restore from backup"
        read -p "Are you sure? (y/N): " -n 1 -r
        echo
        
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            # Remove existing container
            if check_container_exists; then
                print_info "Removing existing container..."
                podman rm -f "$CONTAINER_NAME" > /dev/null
            fi
            
            print_info "Restoring from backup: $BACKUP_FILE"
            
            # Import the backup
            if podman import "$BACKUP_FILE" "$IMAGE_NAME-restored"; then
                # Create new container from restored image
                if podman run -dit \
                    --name "$CONTAINER_NAME" \
                    --hostname redhat-shell \
                    --privileged \
                    --systemd=always \
                    -v "$HOST_VOLUME":"$CONTAINER_MOUNT":rw \
                    "$IMAGE_NAME-restored"; then
                    
                    print_success "Container restored successfully!"
                    print_info "Container '$CONTAINER_NAME' is now running"
                else
                    print_error "Failed to create container from restored image"
                    exit 1
                fi
            else
                print_error "Failed to import backup"
                exit 1
            fi
        else
            print_info "Restore cancelled"
        fi
        ;;
        
    *)
        print_error "Unknown command: $COMMAND"
        echo ""
        show_usage
        exit 1
        ;;
esac
