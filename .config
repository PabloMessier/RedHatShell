# Configuration file for RHEL Shell
# This file allows you to customize the RHEL Shell environment
# Copy this file and modify the values as needed

# ============================================================================
# Container Configuration
# ============================================================================

# Name of the container (default: redhat-shell)
# CONTAINER_NAME="redhat-shell"

# Name of the default user inside the container (default: pablo)
# DEFAULT_USER="pablo"

# ============================================================================
# Volume Mounts
# ============================================================================

# Host directory to mount into the container
# This allows accessing macOS files from within the container
# HOST_VOLUME="/Users"

# Mount point inside the container
# CONTAINER_MOUNT="/mnt/host"

# ============================================================================
# Security Settings
# ============================================================================

# ⚠️  WARNING: The default passwords are "redhat" for both root and pablo
# ⚠️  These are INSECURE and should be changed in production environments!
# 
# To change passwords:
# 1. Enter the container: redhat-shell
# 2. Change user password: passwd
# 3. Change root password: sudo passwd root
#
# Or rebuild the image with custom passwords by editing the Containerfile

# Default password for the default user (used in Containerfile)
# DEFAULT_USER_PASSWORD="redhat"

# Default password for root (used in Containerfile)
# ROOT_PASSWORD="redhat"

# ============================================================================
# Advanced Configuration
# ============================================================================

# Additional podman run options (optional)
# Example: PODMAN_RUN_OPTS="--cpus 2 --memory 4g"
# PODMAN_RUN_OPTS=""

# Enable debug mode (set to "true" to enable verbose output)
# DEBUG="false"
